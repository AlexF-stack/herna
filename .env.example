# Optional: Formspree form ID (overrides FormSubmit)
# Create a form at https://formspree.io pointed to contact@hernaholding.com
# FORMSPREE_ID=xxxxxxxx
# NEXT_PUBLIC_FORMSPREE_ID=xxxxxxxx

# Default delivery uses FormSubmit → brandAssets.email (contact@hernaholding.com).
# Create the mailbox first (Cloudflare Email Routing or Google Workspace).

NEXT_PUBLIC_SITE_URL=https://www.hernaholding.com
